return {
  default = {
    -- The plugin uses `require "plugins.terminal.scroll_math"`, which resolves
    -- under the editor because main.c sets package.path to `EXEDIR/data/?.lua`.
    -- Mirror that here so the spec can `require` the same module path.
    lpath = "./data/?.lua;./data/?/init.lua;;",
    pattern = "_spec",
  },
}
